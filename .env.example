# Pi Client Environment Configuration
# Copy to .env and adjust values for your setup

# === BACKEND CONNECTION ===
BACKEND_URL=http://192.168.68.111:8000
BACKEND_WS_URL=ws://192.168.68.111:8000/ws/mediaplayer/events?detail=minimal

# === HARDWARE MODE ===
# Options: "real" (actual RPi hardware) or "mock" (development/testing)
HARDWARE_MODE=mock

# === GPIO BUTTON PINS ===
# Standard Raspberry Pi GPIO pinout
BUTTON_1_GPIO=18        # Previous track
BUTTON_2_GPIO=24        # Play/Pause
BUTTON_3_GPIO=14        # Next track
BUTTON_4_GPIO=23        # Stop
BUTTON_5_GPIO=17        # Custom function
BUTTON_BOUNCETIME=200   # Debounce in milliseconds
BUTTON_LONG_PRESS_TIME=1000  # Long press threshold in milliseconds

# === ROTARY ENCODER PINS ===
# Volume control encoder
ROTARY_ENCODER_PIN_A=27  # Connected to rotary encoder DT
ROTARY_ENCODER_PIN_B=22  # Connected to rotary encoder CLK
ENCODER_BOUNCETIME=10    # Debounce in milliseconds

# === NFC CARD READER ===
NFC_CARD_SWITCH_GPIO=15   # Card insertion detection
RFID_CS_PIN=7            # Chip select for SPI

# === DISPLAY CONFIGURATION ===
DISPLAY_WIDTH=480
DISPLAY_HEIGHT=320
DISPLAY_ROTATION=0
DISPLAY_POWER_GPIO=20    # Power control
DISPLAY_BACKLIGHT_GPIO=18  # Backlight PWM
DISPLAY_GPIO_CS=8        # ILI9488 chip select
DISPLAY_GPIO_DC=6        # ILI9488 data/command
DISPLAY_GPIO_RST=5       # ILI9488 reset

# === FONT CONFIGURATION ===
FONT_BASE_PATH=fonts

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=logs/pi_client.log
LOG_SERVER_HOST=192.168.68.102  # Syslog server (same as backend server recommended)
LOG_SERVER_PORT=514             # Standard syslog UDP port

# === CONNECTION MONITORING ===
HEARTBEAT_INTERVAL=30    # WebSocket heartbeat in seconds
RECONNECT_DELAY=5        # Reconnection attempt delay in seconds
MAX_RECONNECT_ATTEMPTS=0  # 0 = infinite retries
